{
  "project": "gistcaster",
  "role": "oss-cli",
  "defaultBranch": "main",
  "reviewRules": {
    "requireTaskLink": true,
    "requireSourceVisibility": true,
    "requireExplicitNetworkTests": true
  },
  "verification": [
    "npm run check",
    "npm run smoke",
    "bash scripts/validate.sh"
  ],
  "release": {
    "npmPublish": false,
    "githubRelease": true,
    "branchProtection": "best-effort"
  }
}
