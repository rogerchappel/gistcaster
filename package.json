{
  "name": "gistcaster",
  "version": "0.1.0",
  "description": "Local-first research capture CLI that turns URLs and files into source-linked Markdown briefs for agents.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./cli": "./src/cli.js"
  },
  "files": [
    "src",
    "docs",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js && node --test",
    "smoke": "node src/cli.js brief tests/fixtures/local-note.md --out /tmp/gistcaster-smoke.md && test -s /tmp/gistcaster-smoke.md",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run build && npm run smoke && npm run package:smoke",
    "build": "node --check src/*.js"
  },
  "keywords": [
    "research",
    "markdown",
    "agents",
    "local-first",
    "cli",
    "summarization"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "bin": {
    "gistcaster": "src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/gistcaster.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/gistcaster/issues"
  },
  "homepage": "https://github.com/rogerchappel/gistcaster#readme"
}
